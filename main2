/*
   ESP32-C3 Super Mini + TMC2209
   Controle de força por Serial (0 a 7)
   - Digite um número de 0 a 7 no Serial Monitor
   - O motor avança com a força escolhida
   - Depois retorna para a posição inicial
   - E fica aguardando o próximo comando

   Ligações:
   -------------------------
   DIR    -> GPIO 10
   STEP   -> GPIO 9
   ENABLE -> GPIO 8
*/

#define EN_PIN    8
#define DIR_PIN   10
#define STEP_PIN  9

// Delay em microssegundos para cada nível de força (0 = mais fraco/lento, 7 = mais forte/rápido)
// Quanto MENOR o delay, mais rápido o motor gira (mais "força" aparente)
const int forcaVelocidade[8] = {900, 800, 700, 600, 500, 400, 300, 200};

// Quantidade de passos que o motor vai avançar em cada acionamento
const int passosMovimento = 2000;

long contadorPassos = 0;

void passo(int velocidade) {
  digitalWrite(STEP_PIN, HIGH);
  delayMicroseconds(velocidade);

  digitalWrite(STEP_PIN, LOW);
  delayMicroseconds(velocidade);
}

void setup() {
  Serial.begin(115200);

  pinMode(EN_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);
  pinMode(STEP_PIN, OUTPUT);

  digitalWrite(EN_PIN, LOW); // habilita driver

  Serial.println("Motor iniciado");
}

void loop() {

  if (Serial.available() > 0) {
    int nivel = Serial.parseInt();

    // Limpa qualquer lixo restante no buffer (ex: '\n')
    while (Serial.available() > 0) {
      Serial.read();
    }

    if (nivel >= 0 && nivel <= 7) {

      int velocidade = forcaVelocidade[nivel];

      Serial.print("Forca selecionada: ");
      Serial.println(nivel);

      // Vai para frente
      digitalWrite(DIR_PIN, HIGH);
      for (int i = 0; i < passosMovimento; i++) {
        passo(velocidade);
        contadorPassos++;
      }

      delay(300); // pequena pausa antes de voltar

      // Retorna para a posicao inicial
      digitalWrite(DIR_PIN, LOW);
      for (int i = 0; i < passosMovimento; i++) {
        passo(velocidade);
        contadorPassos--;
      }
  
      Serial.print("Posicao: ");
      Serial.println(contadorPassos);
      Serial.println("Aguardando novo comando (0 a 7):");

    } else {
      Serial.println("Valor invalido! Digite um numero de 0 a 7.");
    }
  }
}
